# Home Assistant
HA_URL=http://192.168.100.190:8123
HA_TOKEN=your_long_lived_access_token_here

# Server
PORT=3001
HOST=0.0.0.0

# CORS allowlist (comma-separated, no wildcards)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Logging: fatal | error | warn | info | debug | trace
LOG_LEVEL=info

# Throttle de state_changed por entity_id (ms)
STATE_THROTTLE_MS=100

# Hosts adicionales (comma-separated, host:port) permitidos para proxy de imágenes.
# El host del HA siempre está implícitamente permitido. Útil para artwork
# servido por Music Assistant u otros plugins en otra IP/puerto.
# Ejemplo: IMAGE_PROXY_EXTRA_HOSTS=192.168.100.190:8095
IMAGE_PROXY_EXTRA_HOSTS=
